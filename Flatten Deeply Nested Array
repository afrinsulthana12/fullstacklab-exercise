/**
 * @param {Array} arr
 * @param {number} depth
 * @return {Array}
 */
var flat = function (arr, n) {
    // If depth is 0, no flattening is needed
    if (n === 0) return arr;

    let result = [];

    for (const item of arr) {
        // If the item is an array and we haven't reached depth n
        if (Array.isArray(item) && n > 0) {
            // Recursively flatten the sub-array with decreased depth
            result.push(...flat(item, n - 1));
        } else {
            // Otherwise, just push the item as is
            result.push(item);
        }
    }

    return result;
};
